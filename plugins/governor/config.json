{
  "plugin_name": "governor",
  "storage_path": "~/.onlooker",
  "governor": {
    "enabled": false,
    "enforcement": "soft",
    "global_policy_path": "~/.onlooker/governance/global-policy.yaml",
    "session": {
      "tokens_default": 100000,
      "cost_usd_default": 1.0,
      "reserve_pct": 10
    },
    "estimation": {
      "safety_margin": 1.3,
      "hard_stop_margin": 1.5,
      "method": "tier_table"
    }
  }
}
